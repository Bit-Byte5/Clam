{
	"geode": "5.7.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "paxcirlot.clam",
	"name": "Clam",
	"version": "1.1.4",
	"developer": "PaxCirlot",
	"description": "Play Geometry Dash with friends.",
	"dependencies": {
		"geode.node-ids": ">=v1.23.3"
	},
	"settings": {
		"ws-port": {
			"type": "int",
			"name": "WebSocket Port",
			"description": "Port for LAN game sessions",
			"default": 8765,
			"min": 1024,
			"max": 65535
		},
		"discovery-port": {
			"type": "int",
			"name": "Discovery Port",
			"description": "UDP port used to find nearby Clam hosts on LAN",
			"default": 8766,
			"min": 1024,
			"max": 65535
		},
		"share-username": {
			"type": "bool",
			"name": "Share Username on LAN",
			"description": "Broadcast your Geometry Dash username to nearby players. Disable to show as Player.",
			"default": true
		}
	}
}
